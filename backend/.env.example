# BirdWatch Backend 환경변수
# 복사 후 실제 값으로 채우세요: cp .env.example .env

# ── 서버 ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# ── 데이터베이스 ──────────────────────────────────────────────────────────────
# docker-compose 로컬: postgresql://birdwatch:birdwatch_dev@localhost:5432/birdwatch
DATABASE_URL=postgresql://birdwatch:birdwatch_dev@localhost:5432/birdwatch

# ── AWS Cognito ───────────────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=ap-northeast-2_XXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=ap-northeast-2
# Cognito Hosted UI 도메인 (https:// 포함 전체 URL)
COGNITO_DOMAIN=https://birdwatch.auth.ap-northeast-2.amazoncognito.com

# ── JWT (Apple Sign-In 자체 발급용) ───────────────────────────────────────────
# 32자 이상: openssl rand -base64 32
JWT_SECRET=replace_with_32_char_min_random_secret_here

# ── AWS S3 / CloudFront ───────────────────────────────────────────────────────
S3_BUCKET=birdwatch-photos-dev
S3_REGION=ap-northeast-2
CLOUDFRONT_DOMAIN=xxxxxxxxxx.cloudfront.net

# ── AI 추론 서버 ──────────────────────────────────────────────────────────────
# docker-compose.ai.yml 기동 시: http://localhost:8001
AI_INFERENCE_URL=http://localhost:8001
AI_MODEL_VERSION=v1.0.0
AI_CONFIDENCE_THRESHOLD=0.85

# ── Rate Limit ────────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
