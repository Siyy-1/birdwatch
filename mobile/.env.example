# BirdWatch Mobile 환경변수
# 복사 후 실제 값으로 채우세요: cp .env.example .env
# Expo는 EXPO_PUBLIC_ 접두어 변수만 클라이언트에 노출됩니다.

# ── API 서버 ──────────────────────────────────────────────────────────────────
# 로컬 docker-compose: http://localhost:3000
# 실기기 테스트 시: http://<로컬IP>:3000  (예: http://192.168.1.10:3000)
EXPO_PUBLIC_API_URL=http://localhost:3000

# ── AWS Cognito ───────────────────────────────────────────────────────────────
EXPO_PUBLIC_COGNITO_USER_POOL_ID=ap-northeast-2_XXXXXXXX
EXPO_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Cognito Hosted UI 도메인 (https:// 포함)
EXPO_PUBLIC_COGNITO_DOMAIN=https://birdwatch.auth.ap-northeast-2.amazoncognito.com

# ── CloudFront CDN ────────────────────────────────────────────────────────────
EXPO_PUBLIC_CDN_DOMAIN=xxxxxxxxxx.cloudfront.net
